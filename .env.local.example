# Base URL of the Mini Trello backend (see mini-trello-backend repo)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api

# Set to "false" once the backend above is ready to integrate against.
# Any other value (or leaving it unset) runs the app entirely on mock data
# stored in the browser's localStorage — no backend required.
NEXT_PUBLIC_USE_MOCK_API=true
